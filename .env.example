# ─────────────────────────────────────────────────────────────────────────────
# .env.example — committed template. NEVER put real secrets here.
# Copy to `.env` (gitignored) and fill in real values.
#
# SECURITY RULE (SR-7 / SR-8): any variable WITHOUT the `NEXT_PUBLIC_` prefix
# stays server-only and is stripped from the client bundle. Secrets (DB URL,
# JWT secret, weather key, Redis token) MUST NOT be prefixed `NEXT_PUBLIC_`,
# or Next.js would inline them into browser-shipped JS. Only truly public,
# non-sensitive values may use `NEXT_PUBLIC_`.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime environment: development | production | test
NODE_ENV="development"

# App origin — used for building absolute URLs and the CORS allowlist (SR-11).
# Safe to expose (it is just the site's public URL).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Database (Supabase PostgreSQL, Singapore region) ─────────────────────────
# DATABASE_URL: pooled connection (PgBouncer, port 6543) used by the app at runtime.
# DIRECT_URL:   direct connection (port 5432) used by Prisma Migrate only.
# Example: postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgres://user:password@host:6543/db?pgbouncer=true"
DIRECT_URL="postgres://user:password@host:5432/db"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign/verify session JWTs (SR-5). Server-only.
# Generate a strong value: `openssl rand -base64 32`
JWT_SECRET="your-secure-jwt-secret-key-min-32-bytes"

# ── Weather provider (server-side proxy only, SR-7) ──────────────────────────
# OpenWeatherMap or WeatherAPI.com key. Server-only — never NEXT_PUBLIC_.
WEATHER_API_KEY="your-weather-api-key"

# ── Rate limiting (Upstash Redis, SR-9) ──────────────────────────────────────
# If Redis is unavailable for the demo, code falls back to an in-memory limiter
# (documented tradeoff: won't share state across instances).
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
