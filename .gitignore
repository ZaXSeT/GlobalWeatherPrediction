!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local agent orchestration / build scaffolding — not part of the app itself and
# not the graded deliverable, so kept out of the repo.
CLAUDE.md
KICKOFF-PROMPT.md
.agents/
docs/

/src/generated/prisma

# Finished reference implementation, kept locally while the app is rebuilt
# step by step for a clean commit history. Not committed.
/_reference/
